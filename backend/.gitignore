# ==========================================
# NOVA DESKTOP - GIT EXCLUSION MANIFEST
# ==========================================

# 1. Dependency Directories
# Excludes heavy local package installations
node_modules/
frontend/node_modules/
backend/node_modules/

# 2. Security & Environment Variables
# CRITICAL: Prevents exposure of MongoDB Atlas credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# 3. Build Outputs
# Excludes compiled application files generated by Vite and Electron
dist/
dist-electron/
build/
out/
release/

# 4. System & Editor Files
# Excludes OS-specific caches and IDE configurations
.DS_Store
Thumbs.db
.vscode/
.idea/

# 5. Logs & Diagnostic Data
# Excludes local runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log